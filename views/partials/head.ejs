<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="refresh" content="60">
  <title><%= title %> - Rondo Sync</title>
  <link rel="stylesheet" href="/public/style.css">
  <script defer src="/public/favicon-rotate.js"></script>
</head>
<body>
  <div class="dashboard">
    <header>
      <h1>
        <a href="/">
          <img src="/public/rondo_logo.svg" alt="Rondo logo" class="header-logo">
          <span>Rondo Sync</span>
        </a>
      </h1>
      <nav>
        <a href="/" class="<%= page === 'overview' ? 'active' : '' %>">Overview</a>
        <a href="/errors" class="<%= page === 'errors' ? 'active' : '' %>">Errors</a>
        <a href="/beheer/free-fields" class="<%= page === 'beheer' ? 'active' : '' %>">Beheer</a>
      </nav>
      <div class="user-info">
        <span><%= user.displayName %></span>
        <form method="POST" action="/logout" style="display:inline">
          <button type="submit" class="btn-logout">Logout</button>
        </form>
      </div>
    </header>
